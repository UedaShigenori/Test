#: ../../source/introduction.rst:877
msgid "Summary of Commands for the Interactive Session Handler"
msgstr ""

#: ../../source/introduction.rst:879
msgid ""
"The following is the complete list of commands currently available in the"
" interactive session hander."
msgstr ""

#: ../../source/introduction.rst:882
msgid ""
"simulate(\\ *modelname*) Translate a model named *modelname* and simulate"
" it."
msgstr ""

#: ../../source/introduction.rst:885
msgid ""
"simulate(\\ *modelname*\\ [,startTime=<*Real*\\ >][,stopTime=<*Real*\\ "
">][,numberOfIntervals"
msgstr ""

#: ../../source/introduction.rst:886
msgid "=<*Integer*\\ >][,outputInterval=<*Real*\\ >][,method=<*String*\\ >]"
msgstr ""

#: ../../source/introduction.rst:887
msgid "[,tolerance=<*Real*\\ >][,fixedStepSize=<*Real*\\ >]"
msgstr ""

#: ../../source/introduction.rst:897
msgid ""
"[,outputFormat=<*String*\\ >]) Translate and simulate a model, with "
"optional start time, stop time, and optional number of simulation "
"intervals or steps for which the simulation results will be computed. "
"More intervals will give higher time resolution, but occupy more space "
"and take longer to compute. The default number of intervals is 500. It is"
" possible to choose solving method, default is “dassl”, “euler” and "
"“rungekutta” are also available. Output format “mat” is default. “plt” "
"and “mat” (MATLAB) are the only ones that work with the val() command, "
"“csv” (comma separated values) and “empty” (no output) are also available"
" (see section :ref:`alternative-output-formats`)."
msgstr ""

#: ../../source/introduction.rst:899
msgid ""
"plot(\\ *vars*) Plot the variables given as a vector or a scalar, e.g. "
"plot({x1,x2}) or plot(x1)."
msgstr ""

#: ../../source/introduction.rst:902
msgid ""
"plotParametric(\\ *var1*, *var2*) Plot var2 relative to var1 from the "
"most recently simulated model, e.g. plotParametric(x,y)."
msgstr ""

#: ../../source/introduction.rst:905
msgid "cd() Return the current directory."
msgstr ""

#: ../../source/introduction.rst:907
msgid "cd(\\ *dir*) Change directory to the directory given as string."
msgstr ""

#: ../../source/introduction.rst:909
msgid "clear() Clear all loaded definitions."
msgstr ""

#: ../../source/introduction.rst:911
msgid "clearVariables() Clear all defined variables."
msgstr ""

#: ../../source/introduction.rst:913
msgid ""
"dumpXMLDAE(\\ *modelname*, ...) Dumps an XML representation of a model, "
"according to several optional parameters."
msgstr ""

#: ../../source/introduction.rst:916
msgid "exportDAEtoMatlab(\\ *name*) Dumps a Matlab representation of a model."
msgstr ""

#: ../../source/introduction.rst:918
msgid ""
"instantiateModel(\\ *modelname*)Performs code instantiation of a "
"model/class and return a string containing the flat class definition."
msgstr ""

#: ../../source/introduction.rst:921
msgid "list() Return a string containing all loaded class definitions."
msgstr ""

#: ../../source/introduction.rst:923
msgid ""
"list(\\ *modelname*) Return a string containing the class definition of "
"the named class."
msgstr ""

#: ../../source/introduction.rst:926
msgid ""
"listVariables() Return a vector of the names of the currently defined "
"variables."
msgstr ""

#: ../../source/introduction.rst:929
msgid ""
"loadModel(\\ *classname*) Load model or package of name *classname* from "
"the path indicated by the environment variable OPENMODELICALIBRARY."
msgstr ""

#: ../../source/introduction.rst:932
msgid ""
"loadFile(\\ *str*) Load Modelica file (.mo) with name given as string "
"argument *str*."
msgstr ""

#: ../../source/introduction.rst:935
msgid ""
"readFile(\\ *str*) Load file given as string *str* and return a string "
"containing the file content."
msgstr ""

#: ../../source/introduction.rst:938
msgid ""
"runScript(\\ *str*) Execute script file with file name given as string "
"argument *str*."
msgstr ""

#: ../../source/introduction.rst:941
msgid ""
"system(\\ *str*) Execute *str* as a system(shell) command in the "
"operating system; return integer success value. Output into stdout from a"
" shell command is put into the console window."
msgstr ""

#: ../../source/introduction.rst:945
msgid ""
"timing(\\ *expr*) Evaluate expression *expr* and return the number of "
"seconds (elapsed time) the evaluation took."
msgstr ""

#: ../../source/introduction.rst:948
msgid "typeOf(\\ *variable*) Return the type of the *variable* as a string."
msgstr ""

#: ../../source/introduction.rst:950
msgid ""
"saveModel(\\ *str*,\\ *modelname*) Save the model/class with name "
"*modelname* in the file given by the string argument *str*."
msgstr ""

#: ../../source/introduction.rst:953
msgid ""
"val(\\ *variable,timePoint*) Return the (interpolated) value of the "
"*variable* at time *timePoint*."
msgstr ""

#: ../../source/introduction.rst:956
msgid "help() Print this helptext (returned as a string)."
msgstr ""

#: ../../source/introduction.rst:958
msgid "quit() Leave and quit the OpenModelica environment"
msgstr ""

