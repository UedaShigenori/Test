msgstr ""

#: ../../source/optimization.rst:295
msgid "One or several parameters (integer or real variables)"
msgstr ""

#: ../../source/optimization.rst:297
msgid ""
"However, the user must be aware of the large number of simulations an "
"optimization might require."
msgstr ""

